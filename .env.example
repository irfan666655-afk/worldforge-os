PORT=5000

# Roster-api seam (Supabase). Unset -> GET/POST /api/roster return 503 ENV-01
# (fail-closed) and the UI shows the "OFFLINE MOCK" badge. See docs/USAGE.md.
SUPABASE_URL=your-supabase-project-url
SUPABASE_ANON_KEY=your-supabase-anonymous-key

# Payment-webhook seam. Unset -> POST /api/webhooks/payment returns 503 ENV-03.
# Any strong random string; must match the signing secret used by the sender.
WF_WEBHOOK_SECRET=your-webhook-hmac-secret
